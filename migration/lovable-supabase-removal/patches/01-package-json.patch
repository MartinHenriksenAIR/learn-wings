# PATCH 01 — package.json changes
# DRAFT ONLY — DO NOT APPLY without completing auth/DB migration
#
# CORRECTED: pg belongs in functions/package.json, NOT in the root package.json.
# Root package.json is the Vite frontend — pg is a Node.js TCP client and
# cannot be bundled into a browser build. Adding it to the root would either
# fail the Vite build or silently bundle raw TCP socket stubs.

# --- ROOT package.json ---
# Remove Supabase runtime dep and Lovable devDep. Nothing added.
--- a/package.json
+++ b/package.json
@@ -38,7 +38,6 @@
     "@radix-ui/react-tooltip": "^1.2.7",
-    "@supabase/supabase-js": "^2.93.1",
     "@tanstack/react-query": "^5.83.0",
     "@types/papaparse": "^5.5.2",
     "class-variance-authority": "^0.7.1",
@@ -79,7 +79,6 @@
     "jsdom": "^20.0.3",
-    "lovable-tagger": "^1.1.13",
     "postcss": "^8.5.6",
     "tailwindcss": "^3.4.17",

# --- NEW FILE: functions/package.json ---
# Created as part of the functions/ directory (see patches/03-azure-functions-src.patch).
# pg ^8.11 is the Node.js PostgreSQL client for Azure PostgreSQL Flexible Server.
+++ b/functions/package.json
