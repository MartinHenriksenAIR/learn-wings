#!/usr/bin/env bash
# learn-wings pre-push hook
# Checks: (1) session memory freshness, (2) ADR gap, (3) bug/blocked backlog
# To skip in emergencies: git push --no-verify

REPO_ROOT="$(git rev-parse --show-toplevel)"
ENCODED_PATH="$(echo "$REPO_ROOT" | sed 's|/|-|g')"
MEMORY_DIR="$HOME/.claude/projects/${ENCODED_PATH}/memory"
ADR_DIR="$REPO_ROOT/docs/adr"
WARN=0

echo "[pre-push] Running learn-wings checks..."
echo ""

# ── 1. Session memory freshness ─────────────────────────────────────────────
# Warns if project_migration_status.md is older than the latest commit.
# Fix: run /cavemem in Claude Code before pushing.
MEM_FILE="$MEMORY_DIR/project_migration_status.md"
if [ -f "$MEM_FILE" ]; then
  MEM_TIME=$(stat -f%m "$MEM_FILE" 2>/dev/null || stat -c%Y "$MEM_FILE" 2>/dev/null || echo 0)
  LAST_COMMIT=$(git log -1 --format="%ct" 2>/dev/null || echo 9999999999)
  if [ "$MEM_TIME" -lt "$LAST_COMMIT" ]; then
    echo "[pre-push] ⚠  MEMORY STALE: project_migration_status.md predates last commit."
    echo "           Run /cavemem in Claude Code to sync session state."
    WARN=$((WARN+1))
  else
    echo "[pre-push] ✓  Memory: project_migration_status.md is current."
  fi
else
  echo "[pre-push] ⚠  MEMORY MISSING: No project_migration_status.md found."
  echo "           Run /cavemem in Claude Code."
  WARN=$((WARN+1))
fi

# ── 2. ADR gap check ────────────────────────────────────────────────────────
# Counts source file changes since the last ADR was added to docs/adr/.
# >3 changes without a new ADR suggests a decision may be undocumented.
# Fix: use adr-kit (adr_create via Claude Code MCP) to record the decision.
LAST_ADR_COMMIT=$(git log --oneline --diff-filter=A -- "$ADR_DIR/ADR-*.md" 2>/dev/null | head -1 | cut -d' ' -f1)
if [ -n "$LAST_ADR_COMMIT" ]; then
  SRC_CHANGES=$(git diff --name-only "${LAST_ADR_COMMIT}..HEAD" -- functions/ src/ 2>/dev/null | wc -l | tr -d ' ')
  if [ "$SRC_CHANGES" -gt 3 ]; then
    echo "[pre-push] ⚠  ADR GAP: ${SRC_CHANGES} source files changed since last ADR commit (${LAST_ADR_COMMIT})."
    echo "           Review: do any new decisions need documenting via adr_create?"
    git diff --name-only "${LAST_ADR_COMMIT}..HEAD" -- functions/ src/ 2>/dev/null | head -8 | sed 's/^/           /'
    WARN=$((WARN+1))
  else
    echo "[pre-push] ✓  ADR gap: ${SRC_CHANGES} source changes since last ADR — looks covered."
  fi
else
  echo "[pre-push] ✓  ADR gap: no ADR history found (first push or clean state)."
fi

# ── 3. Bug / blocked backlog ────────────────────────────────────────────────
# Scans memory files, docs/, and handoverguide.md for unresolved markers.
# Fix: resolve or record items in session memory / open GitHub issues.
SCAN_DIRS=()
[ -d "$MEMORY_DIR" ] && SCAN_DIRS+=("$MEMORY_DIR")
[ -d "$REPO_ROOT/docs" ] && SCAN_DIRS+=("$REPO_ROOT/docs")
[ -f "$REPO_ROOT/handoverguide.md" ] && SCAN_DIRS+=("$REPO_ROOT/handoverguide.md")

if [ ${#SCAN_DIRS[@]} -gt 0 ]; then
  BACKLOG_FILES=$(grep -rl \
    "KNOWN BUG\|BLOCKED\|TODO.*security\|TODO.*auth\|adr-kit.*bug\|kschlt/adr-kit" \
    "${SCAN_DIRS[@]}" 2>/dev/null | grep -v "\.git" | wc -l | tr -d ' ')
  if [ "$BACKLOG_FILES" -gt 0 ]; then
    echo "[pre-push] ⚠  BUG BACKLOG: ${BACKLOG_FILES} file(s) contain unresolved markers:"
    grep -rl \
      "KNOWN BUG\|BLOCKED\|TODO.*security\|TODO.*auth\|adr-kit.*bug\|kschlt/adr-kit" \
      "${SCAN_DIRS[@]}" 2>/dev/null | grep -v "\.git" \
      | sed "s|$REPO_ROOT/||;s|$HOME/||" | head -6 | sed 's/^/           /'
    echo "           Review and record status in session memory before continuing."
    WARN=$((WARN+1))
  else
    echo "[pre-push] ✓  Bug backlog: no unresolved markers found."
  fi
fi

# ── Summary ─────────────────────────────────────────────────────────────────
echo ""
if [ "$WARN" -gt 0 ]; then
  echo "[pre-push] ⚠  ${WARN} warning(s) — push will continue."
  echo "           Address warnings in Claude Code: /cavemem, adr_create, or update memory."
  echo "           To skip checks: git push --no-verify"
else
  echo "[pre-push] ✓  All checks passed."
fi
echo ""
exit 0
